# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_WRITE_TOKEN=your_sanity_write_token_with_editor_role

# SMTP (Email Delivery)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
CONTACT_FORM_RECEIVER=receiver_email@example.com

# Basic Auth dla środowisk nieprodukcyjnych (TEST) — brak wartości = dostęp zablokowany
TEST_BASIC_AUTH_USER=your_basic_auth_user
TEST_BASIC_AUTH_PASS=your_basic_auth_password

